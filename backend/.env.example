# Database
DATABASE_URL="postgresql://user:password@localhost:5432/magelang?schema=public"

# JWT Configuration
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRE="900"
REFRESH_TOKEN_EXPIRE="604800"

# Redis (Optional - fallback to memory cache if not available)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# OpenAI API
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Server
PORT=4000
NODE_ENV="development"
